---
import { getCollection } from 'astro:content'

import Lightbox from '@/components/Lightbox.astro'

type Props = {
  year: string
  isPromotion?: boolean
}

const { year } = Astro.props

const galleryId = `gallery-${year}`

const isHigher = (index: number, pattern: number[], start = 0): boolean =>
  pattern.includes((index - start) % (pattern[pattern.length - 1] ?? 0))

const events = await getCollection('events')
const event = events.find((e) => e.id === year)
const imageUrls = event?.data.images ?? []
---

{
  (
    <>
      <div class="grid grid-cols-2 gap-2 md:grid-cols-4 md:gap-3" id={galleryId}>
        {imageUrls.map((url, index) => (
          <button
            type="button"
            class:list={[
              'relative block w-full cursor-pointer overflow-hidden rounded-lg border-0 bg-transparent p-0 text-left transition-opacity hover:opacity-90 max-md:aspect-3/2',
              index === 0 && 'md:col-span-2 md:col-start-2 md:row-span-2',
              index === 1 && 'md:col-start-1 md:mt-auto md:ml-auto md:w-2/3',
              index === 2 && 'md:col-start-1',
              isHigher(index, [0, 6, 14], 4) && 'md:col-span-2 md:row-span-2',
              isHigher(index, [0, 6, 9, 12, 14]) && 'md:row-span-2',
              isHigher(index, [0, 5]) && 'max-md:col-span-2',
            ]}
            data-gallery={galleryId}
            data-index={index}
            aria-label={`Open image ${String(index + 1)} in lightbox`}
          >
            <img
              src={url}
              alt=""
              width={800}
              height={533}
              class="size-full max-h-full max-w-full object-cover"
              loading="lazy"
            />
          </button>
        ))}
      </div>
      <Lightbox imageUrls={imageUrls} {galleryId} />
    </>
  )
}

<script>
  document
    .querySelectorAll<HTMLButtonElement>('[data-gallery][data-index]')
    .forEach((btn) => {
      btn.addEventListener('click', () => {
        const index = parseInt(btn.dataset.index ?? '0', 10)
        const galleryId = btn.dataset.gallery ?? ''
        document.dispatchEvent(
          new CustomEvent('gallery:open', { detail: { index, galleryId } }),
        )
      })
    })
</script>
