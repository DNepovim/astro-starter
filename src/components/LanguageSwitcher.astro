---
import { getRelativeLocaleUrl } from 'astro:i18n'
import { getLocale, locales } from '@/paraglide/runtime'

const currentLocale = getLocale()

// Strip current locale prefix to get the base path
const pathname = Astro.url.pathname.replace(/\/$/, '') || '/'
let basePath = pathname
for (const locale of locales) {
  if (locale === 'en') continue
  if (pathname === `/${locale}`) { basePath = '/'; break }
  if (pathname.startsWith(`/${locale}/`)) { basePath = pathname.slice(locale.length + 1); break }
}
---

<nav class="flex gap-3 text-sm">
  {locales.map((lang) => (
    <a
      href={getRelativeLocaleUrl(lang, basePath)}
      class:list={[
        'uppercase transition-opacity',
        lang === currentLocale
          ? 'opacity-100 underline underline-offset-4'
          : 'opacity-40 hover:opacity-70',
      ]}
    >
      {lang}
    </a>
  ))}
</nav>
