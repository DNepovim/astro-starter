---
import type { CollectionEntry } from "astro:content";
import { getLocale } from "@/paraglide/runtime";
import * as m from "@/paraglide/messages";

type Props = {
  season: CollectionEntry<"events">;
  isActive?: boolean;
  editionNumber: number;
};

const { season, isActive, editionNumber } = Astro.props;
const locale = getLocale();
const dateLocale = locale === 'cs' ? 'cs-CZ' : 'en-US';
---

<a
  class:list={[
    "relative block overflow-hidden group rounded-lg max-w-64",
    isActive ? "grayscale pointer-events-none" : "hover:grayscale-0 transition-[filter] duration-700",
  ]}
  href={`/event/${season.id}`}
>
  <img
    src={season.data.cover}
    alt=""
    class:list={[
      "w-full rounded-lg origin-top",
      isActive
        ? "scale-118"
        : "group-hover:scale-118 transition-transform duration-700",
    ]}
    width={264}
    height={176}
    loading="lazy"
  />
  <p class="flex flex-col ml-2 gap-2 font-head -mt-11 relative">
    <span class="text-3xl text-white">{m.edition({ number: String(editionNumber) })}</span>
    <span
      class:list={[
        "text-xl",
        isActive
          ? "text-white"
          : "group-hover:text-white transition-colors duration-700",
      ]}
    >
      {season.data.startDate.toLocaleDateString(dateLocale)}
    </span>
  </p>
</a>
